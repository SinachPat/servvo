# Servvo environment — copy to .env and fill in.
# NEVER commit a real .env. Vendor sandboxes only in dev/test.

# ---- Core infrastructure ----
DATABASE_URL="postgresql://servvo:servvo@localhost:5432/servvo?schema=public"
REDIS_URL="redis://localhost:6379"

# ---- Agent-leg OAuth (Servvo as OAuth 2.1 resource server) ----
# Delegated to a managed IdP — do not hand-roll an authorization server.
MCP_PUBLIC_URL="http://localhost:8787"
OAUTH_ISSUER_URL=""
OAUTH_AUDIENCE="https://mcp.servvo.local"
OAUTH_JWKS_URL=""

# ---- Secrets / token custody ----
# Envelope encryption. The local dev key is NOT for production.
KMS_PROVIDER="local"            # local | aws
KMS_KEY_ID=""
LOCAL_DEV_MASTER_KEY=""         # 32-byte base64; dev only

# ---- Vendor OAuth (Servvo as OAuth client). Sandbox credentials only. ----
# Square — authorization-code OAuth, per merchant
SQUARE_ENVIRONMENT="sandbox"
SQUARE_APPLICATION_ID=""
SQUARE_APPLICATION_SECRET=""
SQUARE_REDIRECT_URL="http://localhost:3000/api/connect/square/callback"

# Toast — client-credentials (TOAST_MACHINE_CLIENT); partner program required
TOAST_ENVIRONMENT="sandbox"
TOAST_CLIENT_ID=""
TOAST_CLIENT_SECRET=""
TOAST_API_HOSTNAME=""

# Clover — per-merchant OAuth
CLOVER_ENVIRONMENT="sandbox"
CLOVER_APP_ID=""
CLOVER_APP_SECRET=""

# 7shifts — labor / scheduling
SEVENSHIFTS_API_TOKEN=""

# ---- Dashboard ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
